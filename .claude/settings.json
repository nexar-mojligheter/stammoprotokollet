{
  "enabledMcpjsonServers": [
    "supabase",
    "vercel",
    "github"
  ],
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)"
    ],
    "ask": [
      "Bash(vercel:*)",
      "Bash(stripe:*)",
      "mcp__supabase__create_project",
      "mcp__supabase__confirm_cost",
      "mcp__supabase__deploy_edge_function"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*.local)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(supabase db reset:*)"
    ]
  }
}
